{
  "name": "bodega-stock",
  "version": "0.3.8",
  "description": "Sistema de gestión de stock para bodega",
  "author": "JRNCarrizo",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run icons && npm run build && electron-builder --win --publish never",
    "icons": "node scripts/generate-icons.mjs",
    "postinstall": "electron-builder install-app-deps",
    "build:mobile": "vite build --config vite.config.mobile.ts",
    "cap:sync": "npm run icons && npm run build:mobile && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:add:android": "npx cap add android"
  },
  "dependencies": {
    "@cantoo/capacitor-http-server": "^1.0.6",
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.1",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.469.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "rcedit": "^4.0.1",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "allowScripts": {
    "better-sqlite3": true,
    "electron": true,
    "esbuild": true,
    "fsevents": true
  },
  "build": {
    "appId": "com.jrncarrizo.bodegastock",
    "productName": "ControlStock",
    "copyright": "Copyright © 2026 JRNCarrizo",
    "publish": {
      "provider": "github",
      "owner": "JRNCarrizo",
      "repo": "bodegaStock"
    },
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json",
      "build/icon.png"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icons/icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "icons/icon.ico"
      }
    ],
    "icon": "build/icon.ico",
    "afterPack": "./scripts/after-pack.mjs",
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerLanguages": [
        "es"
      ]
    }
  }
}
